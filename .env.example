# ── Tenant ──────────────────────────────────────────────
TENANT=yeppo   # o tupibox, o cualquier carpeta en tenants/

# ── WhatsApp (Meta Cloud API) ────────────────────────────
WHATSAPP_ACCESS_TOKEN=
PHONE_NUMBER_ID=
WEBHOOK_VERIFY_TOKEN=
BUSINESS_PHONE=

# ── Claude AI ────────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
AI_MONTHLY_BUDGET=10.0

# ── Slack ────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=       # ID del canal (ej: C1234567890)
# o
SLACK_CHANNEL_WHATSAPP= # Nombre del canal (ej: #team-servicio-al-cliente)

# ── Server ───────────────────────────────────────────────
PORT=3000
LOG_FILE=conversations.log

# ── TupiBox-specific (solo si TENANT=tupibox) ────────────
FORM_URL=https://go.tupibox.com
